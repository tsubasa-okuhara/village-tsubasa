# ============================================================
# Streamlit Cloud シークレット設定サンプル
#
# 使い方:
#   1. このファイルをコピーして secrets.toml を作成
#      cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. 各値を自分の値に書き換え
#   3. secrets.toml は .gitignore に入っているので commit されません
#
# Streamlit Cloud の場合:
#   アプリ設定 → Secrets → このファイルと同じ内容を貼り付け
# ============================================================

# アプリのパスワード認証
[auth]
password = "your_strong_password_here"

# Supabase 接続情報
# Supabase ダッシュボード → Project Settings → API から取得
[supabase]
url = "https://xxxxxxxxxxxxx.supabase.co"
# service_role キーを使用 (RLS をバイパスするため)
# ⚠️ anon キーではなく service_role キーを使ってください
key = "eyJhbGciOiJIUzI1NiIs..."

# Claude API キー (Anthropic Console で取得)
[anthropic]
api_key = "sk-ant-xxxxxxxxx"

# 管理者メールアドレス一覧
# ここに登録されたメールでログインしたユーザーは
# 「📊 税理士提出 (管理者)」ページから全ヘルパーのレシートを
# まとめてExcel出力できるようになります。
# 複数人を登録する場合はリストで指定:
#   emails = ["admin@example.com", "manager@example.com"]
[admin]
emails = ["admin@village-support.jp"]
